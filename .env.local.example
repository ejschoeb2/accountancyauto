# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_IS_DEMO=true

# Postmark (Email Delivery)
POSTMARK_SERVER_TOKEN=
ACCOUNTANT_EMAIL=
POSTMARK_SENDER_DOMAIN=        # Domain for outbound emails (must match verified Postmark sender signature)
POSTMARK_WEBHOOK_SECRET=       # Secret token for inbound webhook authentication

# Encryption (AES-256-GCM token encryption — see lib/crypto/tokens.ts)
ENCRYPTION_KEY=                  # Current key: 64-char hex (32 bytes). Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY_PREVIOUS=         # Previous key: set during key rotation only, remove once all rows are re-encrypted

# Cron
CRON_SECRET=

# E2E Testing (Playwright)
E2E_USER_EMAIL=
E2E_USER_PASSWORD=
PLAYWRIGHT_BASE_URL=

# Sentry (optional — error tracking)
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

