# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_IS_DEMO=true

# Postmark (Email Delivery)
POSTMARK_SERVER_TOKEN=
ACCOUNTANT_EMAIL=
POSTMARK_SENDER_DOMAIN=        # Domain for outbound emails (must match verified Postmark sender signature)
POSTMARK_WEBHOOK_SECRET=       # Secret token for inbound webhook authentication

# Cron
CRON_SECRET=

# Sentry (optional — error tracking)
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

